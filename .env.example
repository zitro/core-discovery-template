# Copy this file to .env and fill in only what you need.
# Anything left blank falls back to a safe local default.

# --- Provider selection ------------------------------------------------
LLM_PROVIDER=local          # local | azure  | openai | ollama
STORAGE_PROVIDER=local      # local | azure  (azure = Cosmos DB + Blob)
AUTH_PROVIDER=none          # none  | azure  (azure = Entra ID OIDC)
SEARCH_PROVIDER=none        # none  | bing   | duckduckgo
IMAGE_PROVIDER=none         # none  | local  | azure

# --- Secret key (REQUIRED for PAT encryption + sessions) --------------
# Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=

# --- Project content source (optional) --------------------------------
# Override the host path mounted at /data/projects in the backend.
# Defaults to ./projects when unset. See compose.yaml for examples.
# PROJECTS_SOURCE=../my-content-repo
# PROJECTS_SOURCE=/path/to/content

# --- Azure OpenAI (LLM_PROVIDER=azure) --------------------------------
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# --- OpenAI direct (LLM_PROVIDER=openai) ------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# --- Ollama (LLM_PROVIDER=ollama) -------------------------------------
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.1

# --- Cosmos DB (STORAGE_PROVIDER=azure) -------------------------------
COSMOS_ENDPOINT=
COSMOS_KEY=
COSMOS_DATABASE=core-discovery
COSMOS_ENSURE_COLLECTIONS=true
# IMMUTABLE per Cosmos container -- set before first ensure_collections run.
COSMOS_PARTITION_STRATEGY=id

# --- Entra ID (AUTH_PROVIDER=azure) -----------------------------------
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# --- Bing search (SEARCH_PROVIDER=bing) -------------------------------
BING_SEARCH_API_KEY=

# --- CORS --------------------------------------------------------------
CORS_ORIGINS=["http://localhost:3000"]

# --- Mount paths inside the container (do not change unless you know why)
PROJECTS_ROOT=/data/projects
EXTENSIONS_DIR=/data/extensions
CUSTOMERS_WORKSPACE_ROOT=/data/customers
