{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":semanticCommits",
    ":dependencyDashboard"
  ],
  "schedule": ["before 6am on monday"],
  "labels": ["dependencies"],
  "prConcurrentLimit": 5,
  "rangeStrategy": "pin",
  "packageRules": [
    {
      "description": "Group framework backend + frontend image bumps into one PR so they ship together",
      "matchPackageNames": [
        "ghcr.io/zitro/core-framework-backend",
        "ghcr.io/zitro/core-framework-frontend"
      ],
      "groupName": "core-framework images",
      "commitMessageTopic": "core-framework",
      "automerge": false,
      "minimumReleaseAge": "1 day"
    },
    {
      "description": "Auto-merge patch bumps after CI passes",
      "matchUpdateTypes": ["patch"],
      "matchPackageNames": [
        "ghcr.io/zitro/core-framework-backend",
        "ghcr.io/zitro/core-framework-frontend"
      ],
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": true
    }
  ],
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security"]
  }
}
